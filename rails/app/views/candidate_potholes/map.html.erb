<% content_for :head do %>
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.10.0/mapbox-gl.css" rel="stylesheet">
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.10.0/mapbox-gl.js" nonce="<%= request.content_security_policy_nonce %>"></script>
<% end %>

<% map_candidates = @candidate_potholes.map do |candidate|
  {
    id: candidate.id,
    status: candidate.status,
    status_label: candidate.status.humanize,
    image_validation_status: candidate.image_validation_status,
    image_validation_label: candidate.image_validation_status.humanize,
    latitude: candidate.latitude.to_f,
    longitude: candidate.longitude.to_f,
    detector_confidence: number_to_percentage(candidate.detector_confidence.to_f * 100, precision: 1),
    detector_model_version: candidate.detector_model_version.presence || "unknown",
    captured_at: l(candidate.captured_at, format: :short),
    image_url: candidate.image.attached? ? url_for(candidate.image.variant(:thumb)) : nil,
    show_url: candidate_pothole_path(candidate),
    city_submission_status: candidate.city_submission&.status&.humanize
  }
end %>

<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Pothole map</h1>
      <p class="page-kicker">Geographic review of uploaded candidates.</p>
    </div>
    <div class="button-group">
      <%= link_to "List view", candidate_potholes_path(status: @status), class: "button" %>
      <%= link_to "API docs", "/api-docs", class: "button" %>
    </div>
  </div>

  <div class="toolbar">
    <nav class="segmented" aria-label="Candidate status filters">
    <% [["All", nil], ["Pending", "pending_review"], ["Confirmed", "confirmed"], ["Rejected", "rejected"], ["Submitted", "submitted"], ["Closed", "closed"], ["Duplicates", "duplicate"]].each do |label, status| %>
      <% active = @status == status || (@status.blank? && status.nil?) %>
      <% count = status ? @status_counts.fetch(status, 0) : @candidate_total %>
      <%= link_to map_candidate_potholes_path(status: status), class: "segment #{active ? "active" : ""}" do %>
        <span><%= label %></span>
        <span class="segment-count"><%= count %></span>
      <% end %>
    <% end %>
    </nav>
    <div class="muted"><span class="metric"><%= @candidate_potholes.size %></span> mapped</div>
  </div>

  <section class="map-panel">
    <% if @mapbox_access_token.blank? %>
      <div class="map-token-warning">
        Set <code>MAPBOX_ACCESS_TOKEN</code> before loading this page to render Mapbox tiles.
      </div>
    <% end %>

    <div
      id="candidate-map"
      class="candidate-map"
      data-mapbox-token="<%= @mapbox_access_token %>"
      data-default-center="<%= map_candidates.first ? [map_candidates.first[:longitude], map_candidates.first[:latitude]].to_json : [-75.6972, 45.4215].to_json %>"
    ></div>

    <aside id="candidate-map-inspector" class="map-inspector" aria-live="polite">
      <section class="map-inspector-empty">
        <h2 class="panel-title">Map selection</h2>
        <p class="page-kicker">No selection</p>
      </section>
    </aside>
  </section>

  <template id="candidate-map-data"><%= json_escape(map_candidates.to_json) %></template>
  <script nonce="<%= request.content_security_policy_nonce %>">
    (() => {
      const mapEl = document.getElementById("candidate-map");
      const inspectorEl = document.getElementById("candidate-map-inspector");
      const dataEl = document.getElementById("candidate-map-data");
      if (!mapEl || !inspectorEl || !dataEl || typeof mapboxgl === "undefined") return;

      const candidates = JSON.parse(dataEl.content.textContent);
      const token = mapEl.dataset.mapboxToken;
      if (!token) return;

      mapboxgl.accessToken = token;
      const defaultCenter = JSON.parse(mapEl.dataset.defaultCenter);
      const map = new mapboxgl.Map({
        container: mapEl,
        style: "mapbox://styles/mapbox/satellite-streets-v12",
        center: defaultCenter,
        zoom: candidates.length > 1 ? 11 : 14
      });

      map.addControl(new mapboxgl.NavigationControl({ visualizePitch: true }), "top-right");

      const candidateById = new Map(candidates.map((candidate) => [candidate.id, candidate]));
      const bounds = new mapboxgl.LngLatBounds();
      const featureCollection = {
        type: "FeatureCollection",
        features: candidates.map((candidate) => {
          bounds.extend([candidate.longitude, candidate.latitude]);

          return {
            type: "Feature",
            geometry: {
              type: "Point",
              coordinates: [candidate.longitude, candidate.latitude]
            },
            properties: {
              id: candidate.id,
              status: candidate.status
            }
          };
        })
      };

      map.on("load", () => {
        map.addSource("candidates", {
          type: "geojson",
          data: featureCollection,
          cluster: true,
          clusterMaxZoom: 18,
          clusterRadius: 52
        });

        map.addLayer({
          id: "candidate-clusters",
          type: "circle",
          source: "candidates",
          filter: ["has", "point_count"],
          paint: {
            "circle-color": ["step", ["get", "point_count"], "#155eef", 8, "#9a6700", 20, "#b42318"],
            "circle-radius": ["step", ["get", "point_count"], 20, 8, 25, 20, 31],
            "circle-stroke-color": "#ffffff",
            "circle-stroke-width": 2
          }
        });

        map.addLayer({
          id: "candidate-cluster-count",
          type: "symbol",
          source: "candidates",
          filter: ["has", "point_count"],
          layout: {
            "text-field": ["get", "point_count_abbreviated"],
            "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Bold"],
            "text-size": 12
          },
          paint: {
            "text-color": "#ffffff"
          }
        });

        map.addLayer({
          id: "candidate-points",
          type: "circle",
          source: "candidates",
          filter: ["!", ["has", "point_count"]],
          paint: {
            "circle-color": [
              "match",
              ["get", "status"],
              "confirmed", "#0f7a4f",
              "submitted", "#0f7a4f",
              "closed", "#0f7a4f",
              "rejected", "#b42318",
              "duplicate", "#b42318",
              "#9a6700"
            ],
            "circle-radius": 9,
            "circle-stroke-color": "#ffffff",
            "circle-stroke-width": 2
          }
        });

        map.on("click", "candidate-clusters", (event) => {
          const feature = map.queryRenderedFeatures(event.point, { layers: ["candidate-clusters"] })[0];
          const clusterId = feature.properties.cluster_id;
          const coordinates = feature.geometry.coordinates.slice();
          const source = map.getSource("candidates");

          source.getClusterExpansionZoom(clusterId, (error, zoom) => {
            if (error) return;

            if (zoom <= map.getZoom() + 0.25 || zoom >= 18) {
              focusCoordinates(coordinates, Math.max(map.getZoom(), Math.min(zoom, 18)));
              window.setTimeout(() => openClusterInspector(source, clusterId), 260);
            } else {
              focusCoordinates(coordinates, Math.min(zoom, 19));
            }
          });
        });

        map.on("click", "candidate-points", (event) => {
          const feature = event.features[0];
          const candidate = candidateById.get(Number(feature.properties.id));
          if (!candidate) return;

          focusCoordinates(feature.geometry.coordinates, Math.max(map.getZoom(), 17));
          openCandidateInspector(candidate);
        });

        ["candidate-clusters", "candidate-points"].forEach((layer) => {
          map.on("mouseenter", layer, () => { map.getCanvas().style.cursor = "pointer"; });
          map.on("mouseleave", layer, () => { map.getCanvas().style.cursor = ""; });
        });

        if (candidates.length > 1) {
          map.fitBounds(bounds, { padding: 64, maxZoom: 15 });
        }
      });

      function focusCoordinates(coordinates, zoom) {
        map.easeTo({
          center: coordinates,
          zoom: zoom,
          duration: 240,
          essential: true
        });
      }

      function openClusterInspector(source, clusterId) {
        source.getClusterLeaves(clusterId, 50, 0, (error, leaves) => {
          if (error) return;

          const groupedCandidates = leaves
            .map((leaf) => candidateById.get(Number(leaf.properties.id)))
            .filter(Boolean);

          renderInspector(clusterInspectorContent(groupedCandidates));
        });
      }

      function openCandidateInspector(candidate) {
        renderInspector(candidateInspectorContent(candidate));
      }

      function openCandidateFromCluster(candidate) {
        const coordinates = [candidate.longitude, candidate.latitude];
        focusCoordinates(coordinates, Math.max(map.getZoom(), 19));
        openCandidateInspector(candidate);
      }

      function renderInspector(content) {
        inspectorEl.replaceChildren(content);
      }

      function candidateInspectorContent(candidate) {
        const content = document.createElement("article");
        content.className = "map-inspector-card";

        const header = document.createElement("div");
        header.className = "map-inspector-header";
        header.innerHTML = `
          <div>
            <h2 class="panel-title">Candidate #${candidate.id}</h2>
            <p class="page-kicker mono">${candidate.latitude}, ${candidate.longitude}</p>
          </div>
        `;
        content.appendChild(header);

        if (candidate.image_url) {
          const imageWrap = document.createElement("div");
          imageWrap.className = "map-inspector-image-wrap";
          const image = document.createElement("img");
          image.className = "map-inspector-image";
          image.alt = "Candidate pothole";
          image.src = candidate.image_url;
          imageWrap.appendChild(image);
          content.appendChild(imageWrap);
        }

        content.appendChild(definitionList([
          ["Status", badge(`status-${candidate.status}`, candidate.status_label)],
          ["Image validation", badge(`validation-${candidate.image_validation_status}`, candidate.image_validation_label)],
          ["Confidence", text(candidate.detector_confidence, "metric")],
          ["Model", text(candidate.detector_model_version, "mono")],
          ["Captured", text(candidate.captured_at, "mono")],
          ["City submission", text(candidate.city_submission_status || "Not submitted")]
        ]));

        const actions = document.createElement("div");
        actions.className = "panel-actions";
        const link = document.createElement("a");
        link.className = "button primary";
        link.href = candidate.show_url;
        link.textContent = "Open candidate";
        actions.appendChild(link);
        content.appendChild(actions);

        return content;
      }

      function clusterInspectorContent(groupedCandidates) {
        const content = document.createElement("article");
        content.className = "map-inspector-card";
        const header = document.createElement("div");
        header.className = "map-inspector-header";
        header.innerHTML = `
          <div>
            <h2 class="panel-title">${groupedCandidates.length} nearby candidates</h2>
          </div>
        `;
        content.appendChild(header);

        const list = document.createElement("div");
        list.className = "map-inspector-list";
        groupedCandidates.forEach((candidate) => {
          const item = document.createElement("button");
          item.type = "button";
          item.className = "map-inspector-list-item";

          const media = document.createElement("span");
          media.className = "map-inspector-list-media";
          if (candidate.image_url) {
            const image = document.createElement("img");
            image.alt = "";
            image.src = candidate.image_url;
            media.appendChild(image);
          }

          const body = document.createElement("span");
          body.className = "map-inspector-list-body";
          const title = document.createElement("span");
          title.className = "map-inspector-list-title";
          title.append(text(`#${candidate.id}`, "mono"));
          title.append(badge(`status-${candidate.status}`, candidate.status_label));
          const meta = document.createElement("span");
          meta.className = "map-inspector-list-meta";
          meta.textContent = `${candidate.detector_confidence} · ${candidate.captured_at}`;
          body.append(title, meta);

          const chevron = document.createElement("span");
          chevron.className = "map-inspector-list-action";
          chevron.textContent = "Open";

          item.append(media, body, chevron);
          item.addEventListener("click", () => openCandidateFromCluster(candidate));
          list.appendChild(item);
        });
        content.appendChild(list);

        return content;
      }

      function definitionList(rows) {
        const list = document.createElement("dl");
        list.className = "definition-list";

        rows.forEach(([label, value]) => {
          const row = document.createElement("div");
          row.className = "definition-row";
          const term = document.createElement("dt");
          term.textContent = label;
          const description = document.createElement("dd");
          description.appendChild(value);
          row.append(term, description);
          list.appendChild(row);
        });

        return list;
      }

      function badge(className, value) {
        const element = document.createElement("span");
        element.className = `badge ${className}`;
        element.textContent = value;
        return element;
      }

      function text(value, className = "") {
        const element = document.createElement("span");
        element.className = className;
        element.textContent = value;
        return element;
      }
    })();
  </script>
</div>
