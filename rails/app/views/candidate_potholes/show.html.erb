<div class="page">
  <%= turbo_stream_from @candidate_pothole %>

  <div class="page-header">
    <div>
      <h1 class="page-title">Candidate #<%= @candidate_pothole.id %></h1>
      <p class="page-kicker mono"><%= @candidate_pothole.latitude %>, <%= @candidate_pothole.longitude %> · <%= l @candidate_pothole.captured_at, format: :short %></p>
    </div>
    <div class="button-group">
      <%= link_to "Back", candidate_potholes_path, class: "button" %>
      <%= link_to "Map", map_candidate_potholes_path(status: @candidate_pothole.status), class: "button" %>
      <span class="badge status-<%= @candidate_pothole.status %>"><%= @candidate_pothole.status.humanize %></span>
    </div>
  </div>

  <div class="detail-grid">
    <div class="image-stage">
      <% if @candidate_pothole.image.attached? %>
        <div class="detection-image-frame">
          <%= image_tag @candidate_pothole.image, class: "hero-image" %>
          <%= candidate_bounding_box(@candidate_pothole) %>
          <%= detector_validation_bounding_box(@detector_validation_result) %>
        </div>
      <% else %>
        <div class="empty-state">No image attached.</div>
      <% end %>
    </div>

    <aside class="side-stack">
      <section class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Review controls</h2>
        </div>
        <div class="panel-body">
          <div class="button-group">
            <%= button_to "Confirm", confirm_candidate_pothole_path(@candidate_pothole), method: :patch, class: "button success" %>
            <%= button_to "Reject", reject_candidate_pothole_path(@candidate_pothole), method: :patch, class: "button danger" %>
            <%= button_to "Submit", submit_candidate_pothole_path(@candidate_pothole), class: "button primary" %>
            <%= button_to "Validate detector", validate_detector_candidate_pothole_path(@candidate_pothole), class: "button" %>
          </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Detection</h2>
          <span class="metric"><%= number_to_percentage(@candidate_pothole.detector_confidence.to_f * 100, precision: 1) %></span>
        </div>
        <div class="panel-body">
        <dl class="definition-list">
          <div class="definition-row"><dt>Confidence</dt><dd class="metric"><%= number_to_percentage(@candidate_pothole.detector_confidence.to_f * 100, precision: 1) %></dd></div>
          <div class="definition-row"><dt>Model</dt><dd class="mono"><%= @candidate_pothole.detector_model_version.presence || "unknown" %></dd></div>
          <div class="definition-row"><dt>Captured</dt><dd class="mono"><%= l @candidate_pothole.captured_at, format: :short %></dd></div>
          <div class="definition-row"><dt>Coordinates</dt><dd class="mono"><%= @candidate_pothole.latitude %>, <%= @candidate_pothole.longitude %></dd></div>
          <div class="definition-row"><dt>Bounding box</dt><dd class="mono"><%= @candidate_pothole.bounding_box.presence || "none" %></dd></div>
          <% if @candidate_pothole.duplicate_of.present? %>
            <div class="definition-row"><dt>Duplicate of</dt><dd><%= link_to "Candidate ##{@candidate_pothole.duplicate_of_id}", @candidate_pothole.duplicate_of, class: "link" %></dd></div>
          <% end %>
        </dl>
        <div class="panel-actions">
          <%= link_to "Open map", "https://www.google.com/maps/search/?api=1&query=#{@candidate_pothole.latitude},#{@candidate_pothole.longitude}", target: "_blank", rel: "noopener", class: "button" %>
        </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Image validation</h2>
          <span class="badge validation-<%= @candidate_pothole.image_validation_status %>"><%= @candidate_pothole.image_validation_status.humanize %></span>
        </div>
        <div class="panel-body">
          <dl class="definition-list">
            <div class="definition-row"><dt>Status</dt><dd><%= @candidate_pothole.image_validation_status.humanize %></dd></div>
            <div class="definition-row"><dt>Validated</dt><dd class="mono"><%= @candidate_pothole.image_validated_at.present? ? l(@candidate_pothole.image_validated_at, format: :short) : "not yet" %></dd></div>
            <% if @candidate_pothole.image_validation_results.present? %>
              <div class="definition-row"><dt>Checks</dt><dd class="metric"><%= @candidate_pothole.image_validation_results.fetch("checks", []).count { |check| check["passed"] } %> / <%= @candidate_pothole.image_validation_results.fetch("checks", []).size %></dd></div>
            <% end %>
          </dl>

          <div class="panel-actions">
            <%= button_to "Re-run image validation", revalidate_image_candidate_pothole_path(@candidate_pothole), class: "button" %>
          </div>

          <% if @candidate_pothole.image_validation_error.present? %>
            <p class="flash alert panel-actions"><%= @candidate_pothole.image_validation_error %></p>
          <% end %>

          <% if @candidate_pothole.image_validation_results.present? %>
            <div class="validation-checks panel-actions">
              <% @candidate_pothole.image_validation_results.fetch("checks", []).each do |check| %>
                <div class="validation-check">
                  <span class="mono"><%= check["name"].humanize %></span>
                  <span class="badge <%= check["passed"] ? "validation-accepted" : "validation-rejected" %>">
                    <%= check["passed"] ? "Passed" : "Failed" %>
                  </span>
                  <span class="metric"><%= check["confidence"].present? ? number_to_percentage(check["confidence"].to_f * 100, precision: 1) : "none" %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>

      <% if @detector_validation_result.present? || @detector_validation_error.present? %>
        <section class="panel">
          <div class="panel-header">
            <h2 class="panel-title">Detector validation</h2>
            <% if @detector_validation_result.present? %>
              <span class="badge status-<%= @detector_validation_result["detected"] ? "confirmed" : "rejected" %>"><%= @detector_validation_result["detected"] ? "Detected" : "Missed" %></span>
            <% else %>
              <span class="badge status-failed">Failed</span>
            <% end %>
          </div>
          <div class="panel-body">
            <% if @detector_validation_error.present? %>
              <p class="flash alert"><%= @detector_validation_error %></p>
            <% else %>
              <dl class="definition-list">
                <div class="definition-row"><dt>Result</dt><dd><%= @detector_validation_result["detected"] ? "Detected" : "Missed" %></dd></div>
                <div class="definition-row"><dt>Confidence</dt><dd class="metric"><%= @detector_validation_result["confidence"].present? ? number_to_percentage(@detector_validation_result["confidence"].to_f * 100, precision: 1) : "none" %></dd></div>
                <div class="definition-row"><dt>Threshold</dt><dd class="metric"><%= number_to_percentage(@detector_validation_result["threshold"].to_f * 100, precision: 1) %></dd></div>
                <div class="definition-row"><dt>Model</dt><dd class="mono"><%= @detector_validation_result["model_version"].presence || "unknown" %></dd></div>
                <div class="definition-row"><dt>Bounding box</dt><dd class="mono"><%= @detector_validation_result["bounding_box"].presence || "none" %></dd></div>
              </dl>
            <% end %>
          </div>
        </section>
      <% end %>

      <section class="panel">
        <div class="panel-header">
          <h2 class="panel-title">City submission</h2>
          <% if submission = @candidate_pothole.city_submission %>
            <span class="badge status-<%= submission.status %>"><%= submission.status.humanize %></span>
          <% else %>
            <span class="badge">Not submitted</span>
          <% end %>
        </div>
        <div class="panel-body">
        <% if submission = @candidate_pothole.city_submission %>
          <dl class="definition-list">
            <div class="definition-row"><dt>Connector</dt><dd class="mono"><%= submission.connector %></dd></div>
            <div class="definition-row"><dt>Status</dt><dd><%= submission.status.humanize %></dd></div>
            <div class="definition-row"><dt>External ID</dt><dd class="mono"><%= submission.external_request_id.presence || "none" %></dd></div>
            <div class="definition-row"><dt>External status</dt><dd><%= submission.external_status.presence || "unknown" %></dd></div>
          </dl>
          <% if submission.error_message.present? %>
            <p class="flash alert panel-actions"><%= submission.error_message %></p>
          <% end %>
        <% else %>
          <p class="muted">This candidate has not been queued for city submission.</p>
        <% end %>
        </div>
      </section>
    </aside>
  </div>
</div>
