<div class="mx-auto max-w-5xl px-4 py-8">
  <div class="mb-5 flex items-center justify-between">
    <%= link_to "Back", candidate_potholes_path, class: "text-sm text-blue-700 underline" %>
    <span class="rounded-md bg-gray-100 px-3 py-1 text-sm font-medium text-gray-800"><%= @candidate_pothole.status.humanize %></span>
  </div>

  <div class="grid gap-6 lg:grid-cols-[1fr_360px]">
    <div>
      <% if @candidate_pothole.image.attached? %>
        <%= image_tag @candidate_pothole.image, class: "w-full rounded-lg border border-gray-200 object-cover" %>
      <% end %>
    </div>

    <aside class="space-y-4">
      <section class="rounded-lg border border-gray-200 bg-white p-4">
        <h1 class="mb-3 text-xl font-semibold text-gray-950">Detection</h1>
        <dl class="space-y-2 text-sm">
          <div class="flex justify-between gap-3"><dt class="text-gray-500">Confidence</dt><dd><%= number_to_percentage(@candidate_pothole.detector_confidence.to_f * 100, precision: 1) %></dd></div>
          <div class="flex justify-between gap-3"><dt class="text-gray-500">Model</dt><dd><%= @candidate_pothole.detector_model_version.presence || "unknown" %></dd></div>
          <div class="flex justify-between gap-3"><dt class="text-gray-500">Captured</dt><dd><%= l @candidate_pothole.captured_at, format: :short %></dd></div>
          <div class="flex justify-between gap-3"><dt class="text-gray-500">Coordinates</dt><dd><%= @candidate_pothole.latitude %>, <%= @candidate_pothole.longitude %></dd></div>
        </dl>
        <%= link_to "Open map", "https://www.google.com/maps/search/?api=1&query=#{@candidate_pothole.latitude},#{@candidate_pothole.longitude}", target: "_blank", rel: "noopener", class: "mt-4 inline-block text-sm text-blue-700 underline" %>
      </section>

      <section class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="mb-3 text-lg font-semibold text-gray-950">Review</h2>
        <div class="flex gap-2">
          <%= button_to "Confirm", confirm_candidate_pothole_path(@candidate_pothole), method: :patch, class: "rounded-md bg-green-700 px-4 py-2 text-sm font-medium text-white" %>
          <%= button_to "Reject", reject_candidate_pothole_path(@candidate_pothole), method: :patch, class: "rounded-md bg-red-700 px-4 py-2 text-sm font-medium text-white" %>
          <%= button_to "Submit", submit_candidate_pothole_path(@candidate_pothole), class: "rounded-md bg-gray-950 px-4 py-2 text-sm font-medium text-white" %>
        </div>
      </section>

      <section class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="mb-3 text-lg font-semibold text-gray-950">City submission</h2>
        <% if submission = @candidate_pothole.city_submission %>
          <dl class="space-y-2 text-sm">
            <div class="flex justify-between gap-3"><dt class="text-gray-500">Connector</dt><dd><%= submission.connector %></dd></div>
            <div class="flex justify-between gap-3"><dt class="text-gray-500">Status</dt><dd><%= submission.status.humanize %></dd></div>
            <div class="flex justify-between gap-3"><dt class="text-gray-500">External ID</dt><dd><%= submission.external_request_id.presence || "none" %></dd></div>
            <div class="flex justify-between gap-3"><dt class="text-gray-500">External status</dt><dd><%= submission.external_status.presence || "unknown" %></dd></div>
          </dl>
          <% if submission.error_message.present? %>
            <p class="mt-3 text-sm text-red-700"><%= submission.error_message %></p>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-600">Not submitted yet.</p>
        <% end %>
      </section>
    </aside>
  </div>
</div>
