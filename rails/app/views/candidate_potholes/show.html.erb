<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Candidate #<%= @candidate_pothole.id %></h1>
      <p class="page-kicker mono"><%= @candidate_pothole.latitude %>, <%= @candidate_pothole.longitude %> · <%= l @candidate_pothole.captured_at, format: :short %></p>
    </div>
    <div class="button-group">
      <%= link_to "Back", candidate_potholes_path, class: "button" %>
      <span class="badge status-<%= @candidate_pothole.status %>"><%= @candidate_pothole.status.humanize %></span>
    </div>
  </div>

  <div class="detail-grid">
    <div class="image-stage">
      <% if @candidate_pothole.image.attached? %>
        <%= image_tag @candidate_pothole.image, class: "hero-image" %>
      <% else %>
        <div class="empty-state">No image attached.</div>
      <% end %>
    </div>

    <aside class="side-stack">
      <section class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Review controls</h2>
        </div>
        <div class="panel-body">
          <div class="button-group">
            <%= button_to "Confirm", confirm_candidate_pothole_path(@candidate_pothole), method: :patch, class: "button success" %>
            <%= button_to "Reject", reject_candidate_pothole_path(@candidate_pothole), method: :patch, class: "button danger" %>
            <%= button_to "Submit", submit_candidate_pothole_path(@candidate_pothole), class: "button primary" %>
          </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-header">
          <h2 class="panel-title">Detection</h2>
          <span class="metric"><%= number_to_percentage(@candidate_pothole.detector_confidence.to_f * 100, precision: 1) %></span>
        </div>
        <div class="panel-body">
        <dl class="definition-list">
          <div class="definition-row"><dt>Confidence</dt><dd class="metric"><%= number_to_percentage(@candidate_pothole.detector_confidence.to_f * 100, precision: 1) %></dd></div>
          <div class="definition-row"><dt>Model</dt><dd class="mono"><%= @candidate_pothole.detector_model_version.presence || "unknown" %></dd></div>
          <div class="definition-row"><dt>Captured</dt><dd class="mono"><%= l @candidate_pothole.captured_at, format: :short %></dd></div>
          <div class="definition-row"><dt>Coordinates</dt><dd class="mono"><%= @candidate_pothole.latitude %>, <%= @candidate_pothole.longitude %></dd></div>
          <div class="definition-row"><dt>Bounding box</dt><dd class="mono"><%= @candidate_pothole.bounding_box.presence || "none" %></dd></div>
        </dl>
        <div class="panel-actions">
          <%= link_to "Open map", "https://www.google.com/maps/search/?api=1&query=#{@candidate_pothole.latitude},#{@candidate_pothole.longitude}", target: "_blank", rel: "noopener", class: "button" %>
        </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-header">
          <h2 class="panel-title">City submission</h2>
          <% if submission = @candidate_pothole.city_submission %>
            <span class="badge status-<%= submission.status %>"><%= submission.status.humanize %></span>
          <% else %>
            <span class="badge">Not submitted</span>
          <% end %>
        </div>
        <div class="panel-body">
        <% if submission = @candidate_pothole.city_submission %>
          <dl class="definition-list">
            <div class="definition-row"><dt>Connector</dt><dd class="mono"><%= submission.connector %></dd></div>
            <div class="definition-row"><dt>Status</dt><dd><%= submission.status.humanize %></dd></div>
            <div class="definition-row"><dt>External ID</dt><dd class="mono"><%= submission.external_request_id.presence || "none" %></dd></div>
            <div class="definition-row"><dt>External status</dt><dd><%= submission.external_status.presence || "unknown" %></dd></div>
          </dl>
          <% if submission.error_message.present? %>
            <p class="flash alert panel-actions"><%= submission.error_message %></p>
          <% end %>
        <% else %>
          <p class="muted">This candidate has not been queued for city submission.</p>
        <% end %>
        </div>
      </section>
    </aside>
  </div>
</div>
