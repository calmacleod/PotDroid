<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Candidate potholes</h1>
      <p class="page-kicker">Review detections uploaded from Android. Newest captures are first.</p>
    </div>
    <div class="button-group">
      <%= link_to "Map view", map_candidate_potholes_path(status: @status), class: "button" %>
      <%= link_to "Reconcile duplicates", candidate_pothole_reconciliations_path, class: "button" %>
      <%= link_to "API docs", "/api-docs", class: "button" %>
      <%= button_to "Pair Android app", pairing_sessions_path, class: "button primary" %>
    </div>
  </div>

  <div class="toolbar">
    <nav class="segmented" aria-label="Candidate status filters">
    <% [["All", nil], ["Pending", "pending_review"], ["Confirmed", "confirmed"], ["Rejected", "rejected"], ["Submitted", "submitted"], ["Closed", "closed"], ["Duplicates", "duplicate"]].each do |label, status| %>
      <% active = @status == status || (@status.blank? && status.nil?) %>
        <% count = status ? @status_counts.fetch(status, 0) : @candidate_total %>
        <%= link_to candidate_potholes_path(status: status), class: "segment #{active ? "active" : ""}" do %>
          <span><%= label %></span>
          <span class="segment-count"><%= count %></span>
        <% end %>
    <% end %>
    </nav>
    <div class="muted"><span class="metric"><%= @candidate_potholes.size %></span> visible</div>
  </div>

  <div class="data-panel">
    <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Status</th>
          <th>Image validation</th>
          <th>Confidence</th>
          <th>Model</th>
          <th>Location</th>
          <th>Captured</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @candidate_potholes.each do |candidate| %>
          <tr>
            <td>
              <%= link_to candidate do %>
                <% if candidate.image.attached? %>
                  <span class="detection-thumb-frame">
                    <%= image_tag candidate.image.variant(:thumb), class: "thumbnail", alt: "Candidate pothole capture" %>
                    <%= candidate_bounding_box(candidate) %>
                  </span>
                <% else %>
                  <div class="placeholder-thumb"></div>
                <% end %>
              <% end %>
            </td>
            <td><span class="<%= status_badge_class(candidate.status) %>"><%= candidate.status.humanize %></span></td>
            <td><span class="<%= validation_badge_class(candidate.image_validation_status) %>"><%= candidate.image_validation_status.humanize %></span></td>
            <td class="metric"><%= number_to_percentage(candidate.detector_confidence.to_f * 100, precision: 1) %></td>
            <td class="mono subtle"><%= candidate.detector_model_version.presence || "unknown" %></td>
            <td class="mono">
              <%= link_to "#{candidate.latitude}, #{candidate.longitude}", "https://www.google.com/maps/search/?api=1&query=#{candidate.latitude},#{candidate.longitude}", target: "_blank", rel: "noopener", class: "link" %>
            </td>
            <td class="mono"><%= l candidate.captured_at, format: :short %></td>
            <td><%= link_to "Open", candidate, class: "button" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>

    <% if @candidate_potholes.empty? %>
      <div class="empty-state">No candidate potholes match this filter.</div>
    <% end %>
  </div>
</div>
