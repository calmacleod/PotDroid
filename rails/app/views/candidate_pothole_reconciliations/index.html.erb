<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Reconcile potholes</h1>
      <p class="page-kicker">Review pending detections captured within 90 seconds and 15 meters of each other.</p>
    </div>
    <div class="button-group">
      <%= link_to "Back to candidates", candidate_potholes_path, class: "button" %>
    </div>
  </div>

  <% if @groups.any? %>
    <div class="reconciliation-groups">
      <% @groups.each_with_index do |group, index| %>
        <section class="panel">
          <div class="panel-header">
            <h2 class="panel-title">Likely duplicate group <%= index + 1 %></h2>
            <span class="badge"><%= group.candidates.size %> candidates</span>
          </div>
          <div class="panel-body">
            <div class="definition-list reconciliation-summary">
              <div class="definition-row"><dt>Captured</dt><dd class="mono"><%= l group.started_at, format: :short %> - <%= l group.ended_at, format: :short %></dd></div>
              <div class="definition-row"><dt>Suggested keep</dt><dd><%= link_to "Candidate ##{group.representative.id}", group.representative, class: "link" %></dd></div>
            </div>

            <div class="reconciliation-grid">
              <% group.candidates.each do |candidate| %>
                <article class="candidate-card <%= "suggested" if candidate == group.representative %>">
                  <div class="candidate-card-media">
                    <% if candidate.image.attached? %>
                      <div class="detection-thumb-frame reconciliation-thumb">
                        <%= image_tag candidate.image.variant(:thumb), class: "thumbnail", alt: "Candidate pothole capture" %>
                        <%= candidate_bounding_box(candidate) %>
                      </div>
                    <% else %>
                      <div class="placeholder-thumb reconciliation-thumb"></div>
                    <% end %>
                  </div>
                  <div class="candidate-card-body">
                    <div class="candidate-card-title">
                      <%= link_to "Candidate ##{candidate.id}", candidate, class: "link" %>
                      <% if candidate == group.representative %>
                        <span class="badge status-confirmed">Suggested</span>
                      <% end %>
                    </div>
                    <dl class="definition-list">
                      <div class="definition-row"><dt>Confidence</dt><dd class="metric"><%= number_to_percentage(candidate.detector_confidence.to_f * 100, precision: 1) %></dd></div>
                      <div class="definition-row"><dt>Captured</dt><dd class="mono"><%= l candidate.captured_at, format: :short %></dd></div>
                      <div class="definition-row"><dt>Location</dt><dd class="mono"><%= candidate.latitude %>, <%= candidate.longitude %></dd></div>
                    </dl>
                    <%= button_to "Keep this one", candidate_pothole_reconciliations_path, params: { representative_id: candidate.id, duplicate_ids: group.candidates.reject { |other| other == candidate }.map(&:id) }, class: "button primary" %>
                  </div>
                </article>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">No likely duplicate pothole groups are waiting for reconciliation.</div>
  <% end %>
</div>
