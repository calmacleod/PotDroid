<div class="mx-auto max-w-2xl px-4 py-8">
  <h1 class="text-2xl font-semibold text-gray-950">Pair Android app</h1>
  <p class="mt-2 text-sm text-gray-600">
    Scan this QR code or enter the pairing code in the Android app. The code expires in 15 minutes and can only be used once.
  </p>

  <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6">
    <div class="mx-auto w-fit rounded-lg bg-white p-4">
      <%= @pairing_session.qr_svg(raw_code: @raw_code, api_base_url: ENV.fetch("POTDROID_API_BASE_URL") { request.base_url }).html_safe %>
    </div>

    <dl class="mt-5 space-y-3 text-sm">
      <div>
        <dt class="font-medium text-gray-600">Pairing code</dt>
        <dd class="mt-1 font-mono text-2xl tracking-widest text-gray-950"><%= @raw_code %></dd>
      </div>
      <div>
        <dt class="font-medium text-gray-600">API base URL</dt>
        <dd class="mt-1 break-all font-mono text-gray-950"><%= ENV.fetch("POTDROID_API_BASE_URL") { request.base_url } %></dd>
      </div>
      <div>
        <dt class="font-medium text-gray-600">QR payload</dt>
        <dd class="mt-1 break-all font-mono text-xs text-gray-700"><%= @pairing_payload %></dd>
      </div>
    </dl>
  </div>

  <%= link_to "Back to candidates", candidate_potholes_path, class: "mt-4 inline-block text-sm text-blue-700 underline" %>
</div>
