<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Pair Android app</h1>
      <p class="page-kicker">Scan the QR code or enter the code manually. Codes expire after 15 minutes.</p>
    </div>
    <%= link_to "Back to candidates", candidate_potholes_path, class: "button" %>
  </div>

  <section class="panel">
    <div class="panel-header">
      <h2 class="panel-title">One-time pairing session</h2>
      <span class="badge status-pending">Expires in 15 min</span>
    </div>
    <div class="panel-body">
      <div class="split-panel pairing-panel">
        <div class="qr-column">
          <div class="qr-wrap">
            <%= @pairing_session.qr_svg(raw_code: @raw_code, api_base_url: ENV.fetch("POTDROID_API_BASE_URL") { request.base_url }).html_safe %>
          </div>
          <p class="qr-caption">Scan from the Android app pairing screen.</p>
        </div>

        <dl class="definition-list">
          <div class="definition-row">
            <dt>Pairing code</dt>
            <dd class="mono metric"><%= @raw_code %></dd>
          </div>
          <div class="definition-row">
            <dt>API base URL</dt>
            <dd class="mono"><%= ENV.fetch("POTDROID_API_BASE_URL") { request.base_url } %></dd>
          </div>
          <div class="definition-row">
            <dt>QR payload</dt>
            <dd class="payload-value"><code><%= @pairing_payload %></code></dd>
          </div>
        </dl>
      </div>
    </div>
  </section>
</div>
