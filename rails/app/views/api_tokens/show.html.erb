<div class="page">
  <div class="page-header">
    <div>
      <h1 class="page-title">Android API token</h1>
      <p class="page-kicker">This token is shown once. Store it in the Android debug settings or use QR pairing.</p>
    </div>
    <%= link_to "Back to candidates", candidate_potholes_path, class: "button" %>
  </div>

  <section class="panel">
    <div class="panel-header">
      <h2 class="panel-title">Bearer token</h2>
    </div>
    <div class="panel-body">
      <pre class="token-block"><%= @raw_token %></pre>
    </div>
  </section>
</div>
