#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

cd "$ROOT/rails"
mise exec ruby@4.0.1 -- bundle exec rspec

if [ -x "$ROOT/android/gradlew" ]; then
  cd "$ROOT/android"
  GRADLE_USER_HOME="$ROOT/android/.gradle" ./gradlew testDebugUnitTest
else
  echo "Skipping Android tests: android/gradlew is not present and gradle is not on PATH."
fi
