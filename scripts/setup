#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/../rails"
mise exec ruby@4.0.1 -- bundle install
mise exec ruby@4.0.1 -- bin/rails db:setup

cat <<MSG

Rails is ready.
Android requires Gradle/Android Studio. If adb is not on PATH, add:
  export PATH="\$HOME/Library/Android/sdk/platform-tools:\$PATH"
MSG
