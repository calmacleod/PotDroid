#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/../rails"
mise exec ruby@4.0.1 -- bundle install
mise exec ruby@4.0.1 -- bin/rails db:setup

cat <<MSG

Rails is ready.
For the full dev environment, install Nix + devenv, then run:
  devenv shell

For automatic shell activation:
  direnv allow

The devenv shell provides cloudflared, Android platform-tools, Ruby, JDK 17,
and sets GRADLE_USER_HOME so Android commands do not need a prefix.
MSG
