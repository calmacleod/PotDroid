#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
RAILS_DIR="$ROOT/rails"
LOCAL_TUNNEL_ENV="$ROOT/.local/cloudflare-tunnel.env"
LOCAL_CLOUDFLARED_DIR="$ROOT/.local/cloudflared"
PORT="${PORT:-3000}"
TUNNEL_PID=""
TUNNEL_LOG=""

if [ -f "$LOCAL_TUNNEL_ENV" ]; then
  # shellcheck source=/dev/null
  source "$LOCAL_TUNNEL_ENV"
fi

cleanup() {
  if [ -n "$TUNNEL_PID" ] && kill -0 "$TUNNEL_PID" >/dev/null 2>&1; then
    kill "$TUNNEL_PID" >/dev/null 2>&1 || true
    wait "$TUNNEL_PID" >/dev/null 2>&1 || true
  fi

  if [ -n "$TUNNEL_LOG" ]; then
    rm -f "$TUNNEL_LOG"
  fi
}

trap cleanup EXIT INT TERM

start_tunnel() {
  if [ "${POTDROID_DEV_TUNNEL:-true}" = "false" ]; then
    echo "Cloudflare tunnel: disabled."
    return
  fi

  if ! command -v cloudflared >/dev/null 2>&1; then
    echo "Cloudflare tunnel: cloudflared is not installed or not on PATH."
    return
  fi

  if [ -n "${POTDROID_TUNNEL_ID:-}" ] && [ -n "${POTDROID_TUNNEL_HOSTNAME:-}" ]; then
    start_named_tunnel
    return
  fi

  start_quick_tunnel
}

start_named_tunnel() {
  mkdir -p "$LOCAL_CLOUDFLARED_DIR"

  local tunnel_config="$LOCAL_CLOUDFLARED_DIR/config.yml"
  local credentials_file="${POTDROID_TUNNEL_CREDENTIALS_FILE:-$HOME/.cloudflared/${POTDROID_TUNNEL_ID}.json}"

  cat >"$tunnel_config" <<YAML
tunnel: ${POTDROID_TUNNEL_ID}
credentials-file: ${credentials_file}

ingress:
  - hostname: ${POTDROID_TUNNEL_HOSTNAME}
    service: http://localhost:${PORT}
  - service: http_status:404
YAML

  TUNNEL_LOG="$(mktemp)"
  cloudflared tunnel --config "$tunnel_config" run "$POTDROID_TUNNEL_ID" >"$TUNNEL_LOG" 2>&1 &
  TUNNEL_PID="$!"
  export POTDROID_API_BASE_URL="https://${POTDROID_TUNNEL_HOSTNAME}"

  echo "Cloudflare tunnel: starting ${POTDROID_TUNNEL_HOSTNAME}..."

  for _ in {1..20}; do
    if ! kill -0 "$TUNNEL_PID" >/dev/null 2>&1; then
      cat "$TUNNEL_LOG"
      echo "Cloudflare tunnel: named tunnel failed to start."
      TUNNEL_PID=""
      unset POTDROID_API_BASE_URL
      return
    fi

    sleep 0.25
  done

  echo "Cloudflare tunnel: $POTDROID_API_BASE_URL"
}

start_quick_tunnel() {
  TUNNEL_LOG="$(mktemp)"
  cloudflared tunnel --url "http://localhost:${PORT}" >"$TUNNEL_LOG" 2>&1 &
  TUNNEL_PID="$!"

  echo "Cloudflare tunnel: waiting for public URL..."

  for _ in {1..60}; do
    if ! kill -0 "$TUNNEL_PID" >/dev/null 2>&1; then
      cat "$TUNNEL_LOG"
      echo "Cloudflare tunnel: failed before a URL was emitted."
      TUNNEL_PID=""
      return
    fi

    tunnel_url="$(grep -Eo 'https://[-a-zA-Z0-9]+\.trycloudflare\.com' "$TUNNEL_LOG" | tail -n 1 || true)"
    if [ -n "$tunnel_url" ]; then
      export POTDROID_API_BASE_URL="$tunnel_url"
      echo "Cloudflare tunnel: $POTDROID_API_BASE_URL"
      return
    fi

    sleep 0.5
  done

  echo "Cloudflare tunnel: timed out waiting for URL. Rails will use localhost."
}

start_tunnel

cd "$RAILS_DIR"
echo "Rails API: http://localhost:${PORT}"
if [ -n "${POTDROID_API_BASE_URL:-}" ]; then
  echo "Android API URL: $POTDROID_API_BASE_URL"
else
  echo "Android API URL: unavailable until a tunnel is started."
fi

mise exec ruby@4.0.1 -- bin/dev "$@"
